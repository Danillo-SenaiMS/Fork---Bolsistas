# -----------------------------------------------------------------------------
# Ambiente de producao (.env.prod)
# Copie para .env.prod e preencha as configuracoes nao-secretas.
# Segredos sensiveis sao injetados via Docker Secrets (arquivos em .secrets/).
# -----------------------------------------------------------------------------

# Django
DEBUG=False
ALLOWED_HOSTS=bolsas.example.com,*.bolsas.example.com
CSRF_TRUSTED_ORIGINS=https://bolsas.example.com

# Banco de dados (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bolsas
DB_USER=bolsas
DB_HOST=db
DB_PORT=5432
# DB_PASSWORD deve ser injetado via Docker Secret DB_PASSWORD_FILE

# Cache / Celery result backend
CACHE_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/0
RABBITMQ_USER=bolsas
RABBITMQ_HOST=rabbitmq
RABBITMQ_VHOST=bolsas
# RABBITMQ_PASSWORD deve ser injetado via Docker Secret RABBITMQ_PASSWORD_FILE

# Provedor de IA: 'groq' (unico suportado)
IA_PROVIDER=groq

# GROQ (Llama 3.3 70B) - API compativel com OpenAI
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY deve ser injetado via Docker Secret GROQ_API_KEY_FILE

# IA_ASYNC: True usa Celery/RabbitMQ/Redis (obrigatorio em producao)
IA_ASYNC=True

# ACME / Cloudflare (Let's Encrypt DNS-01)
ACME_EMAIL=seu-email@example.com
# CF_DNS_API_TOKEN deve ser injetado via Docker Secret CF_DNS_API_TOKEN_FILE

# Traefik / deploy
DOMAIN=bolsas.example.com
REGISTRY=seu-registry.exemplo.com
TAG=latest
