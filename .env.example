# -----------------------------------------------------------------------------
# Ambiente de desenvolvimento local (.env)
# Copie este arquivo para .env e preencha os valores reais.
# .env e .env.prod nao devem ser commitados.
# -----------------------------------------------------------------------------

# Django
SECRET_KEY=change-me-dev-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,bolsas.localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://bolsas.localhost

# Banco de dados (dev: SQLite ou Postgres)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=bolsas
# DB_USER=bolsas
# DB_PASSWORD=bolsas
# DB_HOST=db
# DB_PORT=5432

# Cache / Celery (dev local sem Docker: locmem + memory broker)
# Em Docker dev, esses valores sao sobrescritos no docker-compose.yml
CACHE_URL=locmemcache://
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# Provedor de IA: 'groq' (unico suportado)
IA_PROVIDER=groq

# GROQ (Llama 3.3 70B) - API compativel com OpenAI
GROQ_API_KEY=sua-chave-groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# IA_ASYNC: False executa as tarefas de IA sincronamente no runserver (dev sem Docker)
IA_ASYNC=False
