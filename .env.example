# -----------------------------------------------------------------------------
# Ambiente de desenvolvimento local (.env)
# Copie este arquivo para .env e preencha os valores reais.
# .env e .env.prod nao devem ser commitados.
# -----------------------------------------------------------------------------

# Django
SECRET_KEY=change-me-dev-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,bolsas.localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://bolsas.localhost

# Banco de dados (dev: SQLite ou Postgres)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=bolsas
# DB_USER=bolsas
# DB_PASSWORD=bolsas
# DB_HOST=db
# DB_PORT=5432

# Cache / Celery result backend
CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google Gemini (modelo gratuito)
GOOGLE_API_KEY=sua-chave-google-ai
GOOGLE_MODEL=gemini-1.5-flash
